day = int(input())
month = int(input())
year = int(input())

def is_leap(year):
	return (year % 400 == 0) or (year % 4 == 0 and year % 100 != 0)

if year <= 0:
	print("Invalid Date")

elif month < 1 or month > 12:
	print("Invalid Date")

else:
	days_in_month = {
		1: 31, 2: 29 if is_leap(year) else 28, 3: 31, 4: 30, 5: 31, 6: 30, 7: 31, 8: 31, 9: 30, 10: 31, 11: 30, 12: 31
	}

	if day < 1 or day > days_in_month[month]:
		print("Invalid Date")
	else:
		day += 1

		if day > days_in_month[month]:
			day = 1
			month += 1

			if month > 12:
				month = 1
				year += 1

				if month > 12:
					month = 1
					year += 1

		print(f"{day:02d}-{month:02d}-{year}")
